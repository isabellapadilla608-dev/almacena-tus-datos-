<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar / Actualizar Producto</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <div class="form-container">
        <h2>Registrar / Actualizar Producto</h2>
        
        <form id="product-form" onsubmit="registrarProducto(event)">
            
            <div class="form-group">
                <label for="id-equipo">ID Equipo / Producto:</label>
                <input type="text" id="id-equipo" placeholder="Ej: EQ-001" required>
            </div>

            <div class="form-group">
                <label for="nombre-modelo">Nombre / Modelo:</label>
                <input type="text" id="nombre-modelo" placeholder="Ej: Laptop Dell Inspiron 15" required>
            </div>

            <div class="form-group">
                <label for="usuario-empleado">Usuario / Empleado:</label>
                <input type="text" id="usuario-empleado" placeholder="Ej: Juan Pérez" required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="precio-original">Precio Original ($):</label>
                    <input type="number" id="precio-original" step="0.01" placeholder="Ej: 1200.00" oninput="calcularDescuento()">
                </div>
                <div class="form-group">
                    <label for="precio-final">Precio Final ($):</label>
                    <input type="number" id="precio-final" step="0.01" placeholder="Ej: 999.99" required oninput="calcularDescuento()">
                </div>
            </div>
            <div id="descuento-preview" class="discount-badge" style="display: none;">0% OFF</div>

            <div class="form-row">
                <div class="form-group">
                    <label for="stock">Disponibilidad (Stock):</label>
                    <input type="number" id="stock" placeholder="Ej: 15" required>
                </div>
                <div class="form-group">
                    <label for="variacion">Variación (Talla/Color/Capacidad):</label>
                    <input type="text" id="variacion" placeholder="Ej: 16GB RAM / Gris" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="fecha-entrega">Fecha de Entrega:</label>
                    <input type="date" id="fecha-entrega" required>
                </div>
                <div class="form-group">
                    <label for="fecha-devolucion">Fecha de Devolución:</label>
                    <input type="date" id="fecha-devolucion">
                </div>
            </div>

            <div class="form-group">
                <label for="estado">Estado:</label>
                <select id="estado" required>
                    <option value="Entregado">Entregado</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Devuelto">Devuelto</option>
                    <option value="Mantenimiento">Mantenimiento</option>
                </select>
            </div>

            <div class="specs-section">
                <h3>Especificaciones Técnicas</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label for="dimensiones">Dimensiones (Al x An x Pr):</label>
                        <input type="text" id="dimensiones" placeholder="Ej: 2cm x 35cm x 23cm">
                    </div>
                    <div class="form-group">
                        <label for="peso">Peso:</label>
                        <input type="text" id="peso" placeholder="Ej: 1.8 kg">
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="imagenes-url">Enlaces de Imágenes/Videos (Separados por coma):</label>
                <input type="text" id="imagenes-url" placeholder="Ej: img1.jpg, img2.jpg">
            </div>

            <div class="form-group">
                <label for="politicas-resenas">Políticas de Envío, Garantía o Reseñas:</label>
                <input type="text" id="politicas-resenas" placeholder="Ej: Envío gratis, 12 meses garantía, link-reseñas.com">
            </div>

            <div class="form-group">
                <label for="notas">Notas:</label>
                <textarea id="notas" placeholder="Ej: Incluye cargador original y funda protectora" rows="3"></textarea>
            </div>

            <button type="submit" class="submit-btn" id="btn-guardar">Añadir al Registro (Sheets)</button>
        </form>
    </div>

    <script src="script.js"></script>
</body>
</html>
