<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Computadoras - Index Software</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <header class="main-header">
        <div class="logo">INDEX SOFTWARE</div>
        <nav class="nav-menu">
            <a href="index.html" class="nav-link">Inicio</a>
            <a href="computadoras.html" class="nav-link active">Computadoras</a>
            <a href="software.html" class="nav-link">Software</a>
            <a href="licencias.html" class="nav-link">Licencias</a>
            <a href="ofertas.html" class="nav-link">Ofertas</a>
            <a href="contacto.html" class="nav-link">Contacto</a>
            <a href="carrito.html" class="nav-link cart-btn">
                <i class="fas fa-shopping-cart"></i> Carrito <span id="cart-count">0</span>
            </a>
        </nav>
    </header>

    <main class="container">
        <h2 class="section-title">Catálogo de Computadoras</h2>
        
        <div class="products-grid">
            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1588872657578-7efd1f1555ed?auto=format&fit=crop&w=500&q=80" alt="Laptop Lenovo IdeaPad 3">
                </div>
                <div class="product-info">
                    <span class="stock-badge">Disponible</span>
                    <h3>Laptop Lenovo IdeaPad 3</h3>
                    <p class="description">Procesador Ryzen 5, 16 GB RAM, SSD de 512 GB. Ideal para estudiantes y productividad diaria.</p>
                    <div class="specs">
                        <span><b>Peso:</b> 1.65 kg</span> | <span><b>Pantalla:</b> 15.6" Fhd</span>
                    </div>
                    <div class="price-container">
                        <span class="price">$11,999 MXN</span>
                    </div>
                    <button class="btn-add-cart" data-id="comp-lenovo" data-name="Laptop Lenovo IdeaPad 3" data-price="11999" data-img="https://images.unsplash.com/photo-1588872657578-7efd1f1555ed?auto=format&fit=crop&w=500&q=80">
                        Agregar al carrito
                    </button>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1593642632823-8f785ba67e45?auto=format&fit=crop&w=500&q=80" alt="HP 15">
                </div>
                <div class="product-info">
                    <span class="stock-badge">Disponible</span>
                    <h3>HP 15</h3>
                    <p class="description">Intel Core i5, 8 GB RAM, 256GB SSD. Excelente rendimiento para oficina y videollamadas.</p>
                    <div class="specs">
                        <span><b>Peso:</b> 1.7 kg</span> | <span><b>Garantía:</b> 1 año</span>
                    </div>
                    <div class="price-container">
                        <span class="price">$10,499 MXN</span>
                    </div>
                    <button class="btn-add-cart" data-id="comp-hp15" data-name="HP 15" data-price="10499" data-img="https://images.unsplash.com/photo-1593642632823-8f785ba67e45?auto=format&fit=crop&w=500&q=80">
                        Agregar al carrito
                    </button>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img">
                    <img src="https://images.unsplash.com/photo-1603302576837-37561b2e2302?auto=format&fit=crop&w=500&q=80" alt="ASUS TUF Gaming">
                </div>
                <div class="product-info">
                    <span class="stock-badge">Disponible</span>
                    <h3>ASUS TUF Gaming</h3>
                    <p class="description">Poder absoluto con Ryzen 7 y tarjeta gráfica dedicada RTX 4050. Lista para gaming y programación pesada.</p>
                    <div class="specs">
                        <span><b>Gráficos:</b> RTX 4050</span> | <span><b>Refresco:</b> 144Hz</span>
                    </div>
                    <div class="price-container">
                        <span class="price">$24,999 MXN</span>
                    </div>
                    <button class="btn-add-cart" data-id="comp-asustuf" data-name="ASUS TUF Gaming" data-price="24999" data-img="https://images.unsplash.com/photo-1603302576837-37561b2e2302?auto=format&fit=crop&w=500&q=80">
                        Agregar al carrito
                    </button>
                </div>
            </div>
        </div>
    </main>

    <script src="cart.js"></script>
</body>
</html>
