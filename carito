<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tu Carrito - Index Software</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <header class="main-header">
        <div class="logo">INDEX SOFTWARE</div>
        <nav class="nav-menu">
            <a href="index.html" class="nav-link">Inicio</a>
            <a href="computadoras.html" class="nav-link">Computadoras</a>
            <a href="software.html" class="nav-link">Software</a>
            <a href="licencias.html" class="nav-link">Licencias</a>
            <a href="ofertas.html" class="nav-link">Ofertas</a>
            <a href="contacto.html" class="nav-link">Contacto</a>
            <a href="carrito.html" class="nav-link cart-btn active">
                <i class="fas fa-shopping-cart"></i> Carrito <span id="cart-count">0</span>
            </a>
        </nav>
    </header>

    <main class="container">
        <h2 class="section-title">Resumen de tu Compra</h2>
        
        <div class="cart-page-container">
            <div class="cart-items-list" id="cart-items-container">
                <p class="empty-cart-msg">Tu carrito está vacío.</p>
            </div>

            <div class="cart-summary-card">
                <h3>Total del Carrito</h3>
                <hr>
                <div class="summary-row">
                    <span>Subtotal:</span>
                    <span id="cart-subtotal">$0 MXN</span>
                </div>
                <div class="summary-row">
                    <span>Envío / Entrega Digital:</span>
                    <span class="free-shipping">Gratis</span>
                </div>
                <hr>
                <div class="summary-row total-row">
                    <span>Total:</span>
                    <span id="cart-total">$0 MXN</span>
                </div>
                <button class="btn-checkout" id="btn-buy-now">Proceder al Pago</button>
                <button class="btn-clear-cart" id="btn-empty-cart">Vaciar Carrito</button>
            </div>
        </div>
    </main>

    <script src="cart.js"></script>
</body>
</html>
